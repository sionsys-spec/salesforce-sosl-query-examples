public with sharing class SearchController {

    @AuraEnabled(cacheable=true)
    public static List<List<SObject>> searchRecords(String searchTerm) {

        List<List<SObject>> searchResults = [
            FIND :searchTerm
            IN NAME FIELDS
            RETURNING
                Account(Id, Name LIMIT 5),
                Product2(Id, Name, ProductCode LIMIT 5)
        ];

        return searchResults;
    }
}


import { LightningElement, track } from 'lwc';
import searchRecords from '@salesforce/apex/SearchController.searchRecords';

export default class SoslSearch extends LightningElement {

    @track results;

    handleSearch(event) {
        const searchTerm = event.target.value;

        if(searchTerm.length > 2){
            searchRecords({ searchTerm })
            .then(data => {
                this.results = data;
            })
            .catch(error => {
                console.error(error);
            });
        }
    }
}

<template>

    <lightning-input
        label="Search"
        onchange={handleSearch}>
    </lightning-input>

    <template if:true={results}>
        <p>Results found!</p>
    </template>

</template>
